{
    "name": "wherd/database",
    "description": "Simple database layer for PHP",
    "type": "library",
    "license": "AFL-3.0",
    "authors": [
        {
            "name": "wher",
            "email": "ola@wherd.dev"
        }
    ],
    "funding": [
        {
            "type": "other",
            "url": "https://www.buymeacoffee.com/wherd"
        }
    ],
    "autoload": {
        "psr-4": {
            "Wherd\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wherd\\Database\\Spec\\": "spec/"
        }
    },
    "require": {
        "php": ">=7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^0.12.49",
        "kahlan/kahlan": "^4.7",
        "friendsofphp/php-cs-fixer": "^2.16"
    },
    "scripts": {
        "fmt": "php-cs-fixer fix src --config .php_cs.dist",
        "analyse": "phpstan analyse --level 8 src",
        "test": "kahlan"
    }
}
